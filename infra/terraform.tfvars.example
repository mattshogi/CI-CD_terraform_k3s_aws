# Copy this file to terraform.tfvars and adjust. Everything is optional —
# the defaults deploy a single SSM-managed node with no SSH and no inbound
# admin access.

# Your public IP (CIDR) for operator access to SSH / kube API / NodePorts.
# Find it with: curl -s https://checkip.amazonaws.com
# Leave unset to keep those ports closed (SSM Session Manager still works).
# admin_cidr = "203.0.113.7/32"

# EC2 key pair name for SSH. Only used when admin_cidr is also set.
# ssh_key_name = "your-ec2-keypair-name"

# t3.micro suffices for cluster + app; use t3.small+ with monitoring enabled.
instance_type = "t3.micro"

# Reuse an existing VPC (avoids per-account VPC limits).
# vpc_id = "vpc-xxxxxxxxx"

# Install Prometheus + Grafana. The Grafana admin password is generated and
# stored in SSM Parameter Store (see grafana_password_ssm_parameter output).
enable_monitoring = false

# Pin the ref the instance bootstraps from (CI passes the commit SHA).
# repo_ref = "main"
